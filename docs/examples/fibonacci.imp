// Procedure to linearly compute and print the first `n` fibonacci numbers

procedure fibonacci(n; f) begin
    f0 := 0;
    f1 := 1;
    while k < n do
        t := f0;
        f0 := f1;
        f1 := f0 + t;
        k := k + 1
    end;
    f := f0
end;

for k := 0 to 100 do
    fibonacci(k; f);
    print f
end
